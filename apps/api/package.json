{
  "name": "@oc-operator/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "cp -r ../web/dist ./web-dist || true",
    "dev": "node --env-file=.env --import=tsx/esm --watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@hono/zod-validator": "^0.7.6",
    "@oc-operator/shared-types": "workspace:*",
    "bullmq": "^5.53.3",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.10",
    "ioredis": "^5.6.1",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "ws": "^8.18.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@oc-operator/tsconfig": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
